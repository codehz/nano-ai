{
  "name": "@codehz/ai",
  "version": "0.6.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codehz/nano-ai.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "test": "bun test",
    "example:basic": "bun run examples/basic.ts",
    "example:multi-turn": "bun run examples/multi-turn.ts",
    "example:tool-loop": "bun run examples/tool-loop.ts",
    "example:server-tools": "bun run examples/server-tools.ts",
    "prepack": "tsdown"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsdown": "^0.22.3",
    "typescript": "^6"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=18"
  }
}
